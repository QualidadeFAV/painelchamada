{
  "manifest_version": 3,
  "name": "Leitor Hospitalar Humano",
  "version": "3.1",
  "description": "Leitura de fichas com voz natural do Google/Edge.",
  "permissions": ["scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}